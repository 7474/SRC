@using SRCTestBlazor.Models
@using System.Linq

<section>
    <nav class="src-sub-nuvbar navbar is-fixed-top">
        @* XXX 常に横幅が入っているとは限らない模様 *@
        <div class="navbar-brand">
            @foreach (var ud in sortedItems)
            {
                var name = ud.Name;
                <a href="#unit-@name" class="navbar-item"
                   @onclick:preventDefault
                   @onclick="@(e => OnClickAnchor("unit-" + name))">@name</a>
            }
        </div>
        <SortControl Labels="@SortOptions.Select(o => o.Label)" OnChanged="OnSortChanged" OnFilterChanged="OnFilterChanged" />
    </nav>
    @if (SettingsService.Settings.ShowComment && !string.IsNullOrEmpty(SRC.UDList.DataComment))
    {
        <div class="content">
            <div class="src-comment">@SRC.UDList.DataComment</div>
        </div>
    }
    @foreach (var ud in sortedItems)
    {
        <UnitDataView Data="@ud" />
    }
</section>

@code {
    [Inject]
    protected IJSRuntime JsInterop { get; set; }
    [Inject]
    private DataViewerSettingsService SettingsService { get; set; }
    [Parameter]
    public SRC SRC { get; set; }

    private string lastRaw = "";
    private bool shouldRender;

    private static readonly List<DataViewerSortOption<SRCCore.Models.UnitData>> SortOptions = new()
    {
        new("定義順"),
        new("名前", u => u.Name),
        new("ＨＰ", u => u.HP),
        new("ＥＮ", u => u.EN),
        new("装甲", u => u.Armor),
        new("運動性", u => u.Mobility),
        new("移動力", u => u.Speed),
        new("最大攻撃力", u => u.Weapons.Select(w => w.Power).DefaultIfEmpty(0).Max()),
        new("最大射程", u => u.Weapons.Select(w => w.MaxRange).DefaultIfEmpty(0).Max()),
    };

    private string _selectedSortLabel = SortOptions[0].Label;
    private bool sortAscending = true;
    private string _filterText = "";
    private IList<SRCCore.Models.UnitData> sortedItems = new List<SRCCore.Models.UnitData>();

    private void RebuildSortedItems()
    {
        var source = string.IsNullOrEmpty(_filterText)
            ? SRC.UDList.Items
            : SRC.UDList.Items.Where(u => u.Raw.Contains(_filterText, StringComparison.OrdinalIgnoreCase));
        var option = SortOptions.FirstOrDefault(o => o.Label == _selectedSortLabel) ?? SortOptions[0];
        if (option.KeySelector == null)
        {
            sortedItems = source.ToList();
        }
        else
        {
            sortedItems = sortAscending
                ? source.OrderBy(option.KeySelector).ToList()
                : source.OrderByDescending(option.KeySelector).ToList();
        }
    }

    private void OnSortChanged((string Label, bool Ascending) args)
    {
        _selectedSortLabel = args.Label;
        sortAscending = args.Ascending;
        RebuildSortedItems();
        shouldRender = true;
    }

    private void OnFilterChanged(string filterText)
    {
        _filterText = filterText;
        RebuildSortedItems();
        shouldRender = true;
    }

    protected override bool ShouldRender() => shouldRender;
    protected override void OnParametersSet()
    {
        shouldRender = lastRaw != SRC.UDList.Raw || sortedItems.Count == 0;
        if (shouldRender)
        {
            lastRaw = SRC.UDList.Raw;
            RebuildSortedItems();
        }
    }
    protected override void OnAfterRender(bool firstRender)
    {
        shouldRender = false;
    }

    private async Task OnClickAnchor(string targetId)
    {
        // 要素までスクロールしてヘッダ分戻る
        await JsInterop.InvokeVoidAsync("anchor.scrollTo", targetId);
        await JsInterop.InvokeVoidAsync("scrollBy", 0, -160);
    }
}
