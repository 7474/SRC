@using System.Linq

<div class="field is-grouped" style="padding: 0.5rem 0.75rem;">
    <div class="control">
        <div class="select is-small">
            <select value="@selectedLabel" @onchange="OnSelectChanged">
                @foreach (var label in Labels)
                {
                    <option value="@label">@label</option>
                }
            </select>
        </div>
    </div>
    <div class="control">
        <button class="button is-small" type="button" @onclick="ToggleSortOrder">
            @(ascending ? "▲" : "▼")
        </button>
    </div>
    <div class="control">
        <input class="input is-small" type="text" placeholder="フィルタ"
               value="@filterText" @oninput="OnFilterInput" />
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<string> Labels { get; set; } = Enumerable.Empty<string>();
    [Parameter]
    public EventCallback<(string Label, bool Ascending)> OnChanged { get; set; }
    [Parameter]
    public EventCallback<string> OnFilterChanged { get; set; }

    private string selectedLabel = "";
    private bool ascending = false;
    private string filterText = "";

    protected override async Task OnParametersSetAsync()
    {
        var firstLabel = Labels.FirstOrDefault();
        if (firstLabel != null && !Labels.Contains(selectedLabel))
        {
            selectedLabel = firstLabel;
            await OnChanged.InvokeAsync((selectedLabel, ascending));
        }
    }

    private async Task OnSelectChanged(ChangeEventArgs e)
    {
        selectedLabel = e.Value?.ToString() ?? "";
        await OnChanged.InvokeAsync((selectedLabel, ascending));
    }

    private async Task ToggleSortOrder()
    {
        ascending = !ascending;
        await OnChanged.InvokeAsync((selectedLabel, ascending));
    }

    private async Task OnFilterInput(ChangeEventArgs e)
    {
        filterText = e.Value?.ToString() ?? "";
        await OnFilterChanged.InvokeAsync(filterText);
    }
}
