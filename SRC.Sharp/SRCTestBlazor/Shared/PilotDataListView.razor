@using SRCTestBlazor.Models
@using System.Linq

<section>
    <nav class="src-sub-nuvbar navbar is-light is-fixed-top">
        <div class="navbar-brand">
            @foreach (var pd in sortedItems)
            {
                var name = pd.Name;
                <a href="#pilot-@name" class="navbar-item"
                   @onclick:preventDefault
                   @onclick="@(e => OnClickAnchor("pilot-" + name))">@name</a>
            }
        </div>
    </nav>
    <SortControl Labels="@SortOptions.Select(o => o.Label)" OnChanged="OnSortChanged" />
    @if (!string.IsNullOrEmpty(SRC.PDList.DataComment))
    {
        <div class="content">
            <div class="src-comment">@SRC.PDList.DataComment</div>
        </div>
    }
    @foreach (var pd in sortedItems)
    {
        <PilotDataView Data="@pd" SRC="@SRC" />
    }
</section>

@code {
    [Inject]
    protected IJSRuntime JsInterop { get; set; }
    [Parameter]
    public SRC SRC { get; set; }

    private string lastRaw = "";
    private bool shouldRender;

    private static readonly List<DataViewerSortOption<SRCCore.Models.PilotData>> SortOptions = new()
    {
        new("名前", p => p.Name),
        new("格闘", p => p.Infight),
        new("射撃", p => p.Shooting),
        new("命中", p => p.Hit),
        new("回避", p => p.Dodge),
        new("技量", p => p.Technique),
        new("反応", p => p.Intuition),
        new("ＳＰ", p => p.SP),
    };

    private string _selectedSortLabel = SortOptions[0].Label;
    private bool sortAscending = true;
    private IList<SRCCore.Models.PilotData> sortedItems = new List<SRCCore.Models.PilotData>();

    private void RebuildSortedItems()
    {
        var option = SortOptions.FirstOrDefault(o => o.Label == _selectedSortLabel) ?? SortOptions[0];
        sortedItems = sortAscending
            ? SRC.PDList.Items.OrderBy(option.KeySelector).ToList()
            : SRC.PDList.Items.OrderByDescending(option.KeySelector).ToList();
    }

    private void OnSortChanged((string Label, bool Ascending) args)
    {
        _selectedSortLabel = args.Label;
        sortAscending = args.Ascending;
        RebuildSortedItems();
        shouldRender = true;
    }

    protected override bool ShouldRender() => shouldRender;
    protected override void OnParametersSet()
    {
        shouldRender = lastRaw != SRC.PDList.Raw;
        if (shouldRender)
        {
            lastRaw = SRC.PDList.Raw;
            RebuildSortedItems();
        }
    }
    protected override void OnAfterRender(bool firstRender)
    {
        shouldRender = false;
    }

    private async Task OnClickAnchor(string targetId)
    {
        // 要素までスクロールしてヘッダ分戻る
        await JsInterop.InvokeVoidAsync("anchor.scrollTo", targetId);
        await JsInterop.InvokeVoidAsync("scrollBy", 0, -160);
    }
}
