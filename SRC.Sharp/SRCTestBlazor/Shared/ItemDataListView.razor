@using SRCTestBlazor.Models
@using System.Linq

<section>
    <nav class="src-sub-nuvbar navbar is-light is-fixed-top">
        <div class="navbar-brand">
            @foreach (var id in sortedItems)
            {
                var name = id.Name;
                <a href="#item-@name" class="navbar-item"
                   @onclick:preventDefault
                   @onclick="@(e => OnClickAnchor("item-" + name))">@name</a>
            }
        </div>
    </nav>
    <SortControl Labels="@SortOptions.Select(o => o.Label)" OnChanged="OnSortChanged" />
    @if (!string.IsNullOrEmpty(SRC.IDList.DataComment))
    {
        <div class="content">
            <div class="src-comment">@SRC.IDList.DataComment</div>
        </div>
    }
    @foreach (var id in sortedItems)
    {
        <ItemDataView Data="@id" SRC="@SRC" />
    }
</section>

@code {
    [Inject]
    protected IJSRuntime JsInterop { get; set; }
    [Parameter]
    public SRC SRC { get; set; }

    private string lastRaw = "";
    private bool shouldRender;

    private static readonly List<DataViewerSortOption<SRCCore.Models.ItemData>> SortOptions = new()
    {
        new("名前", i => i.Name),
        new("ＨＰ", i => i.HP),
        new("ＥＮ", i => i.EN),
        new("装甲", i => i.Armor),
        new("運動性", i => i.Mobility),
        new("移動力", i => i.Speed),
        new("最大攻撃力", i => i.Weapons.Select(w => w.Power).DefaultIfEmpty(0).Max()),
        new("最大射程", i => i.Weapons.Select(w => w.MaxRange).DefaultIfEmpty(0).Max()),
    };

    private string _selectedSortLabel = SortOptions[0].Label;
    private bool sortAscending = true;
    private IList<SRCCore.Models.ItemData> sortedItems = new List<SRCCore.Models.ItemData>();

    private void RebuildSortedItems()
    {
        var option = SortOptions.FirstOrDefault(o => o.Label == _selectedSortLabel) ?? SortOptions[0];
        sortedItems = sortAscending
            ? SRC.IDList.Items.OrderBy(option.KeySelector).ToList()
            : SRC.IDList.Items.OrderByDescending(option.KeySelector).ToList();
    }

    private void OnSortChanged((string Label, bool Ascending) args)
    {
        _selectedSortLabel = args.Label;
        sortAscending = args.Ascending;
        RebuildSortedItems();
        shouldRender = true;
    }

    protected override bool ShouldRender() => shouldRender;
    protected override void OnParametersSet()
    {
        shouldRender = lastRaw != SRC.IDList.Raw;
        if (shouldRender)
        {
            lastRaw = SRC.IDList.Raw;
            RebuildSortedItems();
        }
    }
    protected override void OnAfterRender(bool firstRender)
    {
        shouldRender = false;
    }

    private async Task OnClickAnchor(string targetId)
    {
        // 要素までスクロールしてヘッダ分戻る
        await JsInterop.InvokeVoidAsync("anchor.scrollTo", targetId);
        await JsInterop.InvokeVoidAsync("scrollBy", 0, -160);
    }
}
