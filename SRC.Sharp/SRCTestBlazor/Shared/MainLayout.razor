@inherits LayoutComponentBase
@* XXX HACK https://github.com/jgthms/bulma/issues/1655 *@
<nav class="navbar is-fixed-top is-light" style="z-index: 1000;" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
        <NavLink class="navbar-item" href="#">SRC#DataViewer</NavLink>
        <div class="navbar-item">
            <button class="button is-light is-small" @onclick="OnClickSettings" title="表示設定">
                <span class="icon">
                    <i class="fas fa-cog"></i>
                </span>
            </button>
        </div>
        <div class="navbar-item has-dropdown @(IsTitlesActive ? "is-active" : "") is-hoverable">
            <a class="navbar-link" @onclick="OnClickTitles" @onclick:stopPropagation>
                <span class="icon">
                    @if (TitlesBusy)
                    {
                        <i class="fas fa-spinner"></i>
                    }
                    else
                    {
                        <i class="far fa-folder"></i>
                    }
                </span>
                <span>Titles</span>
            </a>
            <div class="navbar-dropdown">
                <TitleNavMenu />
            </div>
        </div>
    </div>
</nav>

<main class="container is-max-desktop">
    @Body
</main>

<SettingsModal IsVisible="@IsSettingsModalVisible" OnClose="OnSettingsModalClose" />

@implements IDisposable
@code {
    [Inject]
    protected NavigationManager NavigationManager { get; set; }
    [Inject]
    protected IJSRuntime JsInterop { get; set; }
    [Inject]
    private SrcDataContainer DataContainer { get; set; }
    [Inject]
    private DataViewerSettingsService SettingsService { get; set; }

    private bool IsTitlesActive = false;
    private bool IsSettingsModalVisible = false;
    private bool TitlesBusy => DataContainer.IndexBusy;

    private void OnClickTitles()
    {
        IsTitlesActive = !IsTitlesActive;
    }

    private void OnClickSettings()
    {
        IsSettingsModalVisible = true;
    }

    private void OnSettingsModalClose()
    {
        IsSettingsModalVisible = false;
    }

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        DataContainer.OnChange += StateHasChanged;
        await SettingsService.InitializeAsync();
    }

    public void Dispose()
    {
        DataContainer.OnChange -= StateHasChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private async void HandleLocationChanged(object sender, LocationChangedEventArgs e)
    {
        // ナビゲーションがあったらドロップダウンを閉じる
        IsTitlesActive = false;
        // ドロップダウンを閉じるためにフォーカスを外す
        await JsInterop.InvokeVoidAsync("bulma.blur", null);

        StateHasChanged();
    }
}