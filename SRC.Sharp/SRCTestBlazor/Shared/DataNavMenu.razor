@using SRCTestBlazor.Models

<div class="tabs">
    <ul>
        @if (DataDisplayOrder == DataDisplayOrder.PilotFirst)
        {
            <li class="@(currentKind == SrcDataKind.Pilot ? "is-active": "")">
                <a @onclick:preventDefault
                   @onclick="@(e => ChangeKind(e, SrcDataKind.Pilot))">
                    Pilot
                </a>
            </li>
            <li class="@(currentKind == SrcDataKind.Unit ? "is-active": "")">
                <a @onclick:preventDefault
                   @onclick="@(e => ChangeKind(e, SrcDataKind.Unit))">
                    Unit
                </a>
            </li>
        }
        else
        {
            <li class="@(currentKind == SrcDataKind.Unit ? "is-active": "")">
                <a @onclick:preventDefault
                   @onclick="@(e => ChangeKind(e, SrcDataKind.Unit))">
                    Unit
                </a>
            </li>
            <li class="@(currentKind == SrcDataKind.Pilot ? "is-active": "")">
                <a @onclick:preventDefault
                   @onclick="@(e => ChangeKind(e, SrcDataKind.Pilot))">
                    Pilot
                </a>
            </li>
        }
        <li class="@(currentKind == SrcDataKind.Item ? "is-active": "")">
            <a @onclick:preventDefault
               @onclick="@(e => ChangeKind(e, SrcDataKind.Item))">
                Item
            </a>
        </li>
    </ul>
</div>

@code {
    [Parameter]
    public EventCallback<SrcDataKind> OnChangeSrcDataKind { get; set; }

    [Parameter]
    public DataDisplayOrder DataDisplayOrder { get; set; } = DataDisplayOrder.UnitFirst;

    private SrcDataKind currentKind = SrcDataKind.Unit;
    private DataDisplayOrder prevDataDisplayOrder = DataDisplayOrder.UnitFirst;

    protected override void OnParametersSet()
    {
        // DataDisplayOrderが変化したときのみ先頭タブをアクティブに設定する
        if (DataDisplayOrder != prevDataDisplayOrder)
        {
            prevDataDisplayOrder = DataDisplayOrder;
            if (DataDisplayOrder == DataDisplayOrder.PilotFirst && currentKind == SrcDataKind.Unit)
            {
                currentKind = SrcDataKind.Pilot;
                OnChangeSrcDataKind.InvokeAsync(currentKind);
            }
            else if (DataDisplayOrder == DataDisplayOrder.UnitFirst && currentKind == SrcDataKind.Pilot)
            {
                currentKind = SrcDataKind.Unit;
                OnChangeSrcDataKind.InvokeAsync(currentKind);
            }
        }
    }

    private async Task ChangeKind(MouseEventArgs e, SrcDataKind kind)
    {
        if (kind != currentKind)
        {
            currentKind = kind;
            await OnChangeSrcDataKind.InvokeAsync(kind);
        }
    }
}
