{
  "version": "1.0.0",
  "name": "srctestblazor",
  "private": true,
  "scripts": {
    "css-deploy": "npm run css-build && npm run css-postcss",
    "css-build": "sass --silence-deprecation=if-function _sass/main.scss ../wwwroot/css/app.css",
    "css-postcss": "postcss --use autoprefixer --no-map --output ../wwwroot/css/app.css  ../wwwroot/css/app.css",
    "css-watch": "npm run css-deploy -- --watch",
    "crean": "npm run css-deploy",
    "build": "npm run css-deploy",
    "start": "npm-run-all --parallel css-watch"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^5.15.4",
    "autoprefixer": "^10.4.7",
    "bulma": "^1.0.4",
    "sass": "^1.83.2",
    "npm-run-all": "*",
    "postcss": "^8.5.13",
    "postcss-cli": "^9.1.0"
  }
}
